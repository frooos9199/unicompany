rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isPublicProfile() {
      return resource.data.isActive == true && resource.data.role in ['individual', 'company'];
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    function isCompany() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'company';
    }

    function ownsApplicationJob(jobId) {
      return isCompany() &&
        exists(/databases/$(database)/documents/jobs/$(jobId)) &&
        get(/databases/$(database)/documents/jobs/$(jobId)).data.companyId == request.auth.uid;
    }

    function hasApprovedCvAccess(individualId) {
      return isCompany() &&
        exists(/databases/$(database)/documents/cvRequests/$(request.auth.uid + '_' + individualId)) &&
        get(/databases/$(database)/documents/cvRequests/$(request.auth.uid + '_' + individualId)).data.status == 'approved';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isPublicProfile() || isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) || isAdmin();
      // Users can update their own profile, admins can update any
      allow update: if isOwner(userId) || isAdmin();
      // Admins have full management permissions
      allow delete: if isAdmin();
    }

    // Private CV profiles
    match /cvProfiles/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) ||
        isAdmin() ||
        (resource.data.cvVisibility == 'public' && isCompany()) ||
        (resource.data.cvVisibility == 'request_only' && hasApprovedCvAccess(userId))
      );
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // CV Requests
    match /cvRequests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.companyId == request.auth.uid || resource.data.individualId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        (request.resource.data.companyId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
        (resource.data.individualId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Jobs
    match /jobs/{jobId} {
      allow read: if resource.data.status == 'active' || isAdmin();
      allow create: if isAuthenticated() && (request.resource.data.companyId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
        (resource.data.companyId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() &&
        (resource.data.companyId == request.auth.uid || isAdmin());
    }

    // Job applications
    match /applications/{applicationId} {
      allow read: if isAuthenticated() &&
        (resource.data.applicantId == request.auth.uid || ownsApplicationJob(resource.data.jobId) || isAdmin());
      allow create: if isAuthenticated() &&
        (request.resource.data.applicantId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
        (resource.data.applicantId == request.auth.uid || ownsApplicationJob(resource.data.jobId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Conversations
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        (request.auth.uid in request.resource.data.participants || isAdmin());
      allow update: if isAuthenticated() &&
        (isAdmin() || request.auth.uid in resource.data.participants);
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
      allow create: if isAuthenticated() &&
        (request.resource.data.senderId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (isAdmin() || resource.data.userId == request.auth.uid);
    }
  }
}
